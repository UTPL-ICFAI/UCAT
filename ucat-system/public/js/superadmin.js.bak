}

// Function to filter users table by name and role
function filterUsers() {
  // Get filter input values
  const nameFilter = document.getElementById('userNameFilter').value.toLowerCase();
  const roleFilter = document.getElementById('userRoleFilter').value.toLowerCase();
  
  // Get all table rows
  const rows = document.querySelectorAll('#usersTableBody tr');
  // Loop through each row
  rows.forEach(row => {
    // Get cells from row
    const cells = row.querySelectorAll('td');
    // Get user name from first cell
    const name = cells[0].textContent.toLowerCase();
    // Get user role from fifth cell
    const role = cells[4].textContent.toLowerCase();
    
    // Check if row matches filters
    const nameMatch = name.includes(nameFilter);
    const roleMatch = !roleFilter || role.includes(roleFilter);
    
    // Show or hide row based on filter match
    row.style.display = (nameMatch && roleMatch) ? '' : 'none';
  });
}

// Function to open add user modal
function openAddUserModal() {
  // Clear form fields
  document.getElementById('addUserForm').reset();
  // Clear any existing error messages
  document.getElementById('addUserError').textContent = '';
  // Open the add user modal
  openModal('addUserModal');
}

// Function to open edit user modal with pre-filled data
function openEditUserModal(userId, name, age, gender, employmentId, role, userId2) {
  // Store current edit user ID
  editingUserId = userId;
  // Set modal title to Edit mode
  document.getElementById('editUserModalTitle').textContent = 'Edit User';
  // Pre-fill name field
  document.getElementById('editUserName').value = name;
  // Pre-fill age field
  document.getElementById('editUserAge').value = age || '';
  // Pre-fill gender dropdown
  document.getElementById('editUserGender').value = gender || '';
  // Pre-fill employment ID field
  document.getElementById('editUserEmploymentId').value = employmentId;
  // Pre-fill role dropdown
  document.getElementById('editUserRole').value = role;
  // Pre-fill user ID field
  document.getElementById('editUserId').value = userId2;
  // Clear password field (optional for edit)
  document.getElementById('editUserPassword').value = '';
  // Clear any existing error messages
  document.getElementById('editUserError').textContent = '';
  // Open the edit user modal
  openModal('editUserModal');
}

// Function to handle add user form submission
async function handleAddUser(e) {
  // Prevent default form submission
  e.preventDefault();
  // Clear previous error messages
  document.getElementById('addUserError').textContent = '';
  
  // Get form field values
  const name = document.getElementById('addUserName').value.trim();
  const age = document.getElementById('addUserAge').value.trim();
  const gender = document.getElementById('addUserGender').value;
  const employmentId = document.getElementById('addUserEmploymentId').value.trim();
  const role = document.getElementById('addUserRole').value;
  const userId = document.getElementById('addUserUserId').value.trim();
  const password = document.getElementById('addUserPassword').value.trim();
  
  // Validate required fields
  if (!name || !employmentId || !role || !userId || !password) {
    // Show error message
    document.getElementById('addUserError').textContent = 'All fields are required';
    // Stop form processing
    return;
  }
  
  // Validate age if provided
  if (age) {
    // Parse age as integer
    const ageNum = parseInt(age);
    // Check if age is valid (1-99)
    if (!Number.isInteger(ageNum) || ageNum < 1 || ageNum > 99) {
      // Show error message
      document.getElementById('addUserError').textContent = 'Age must be between 1 and 99';
      // Stop form processing
      return;
    }
  }
  
  // Indicate loading state
  showLoading(true);
  try {
    // Send add user request to API
    const response = await fetch('/api/superadmin/users', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        name,
        age: age ? parseInt(age) : null,
        gender: gender || null,
        employment_id: employmentId,
        role,
        user_id: userId,
        password
      })
    });
    
    // Check if request was successful
    if (!response.ok) {
      // Parse error response
      const error = await response.json();
      // Show error message
      document.getElementById('addUserError').textContent = error.error;
      // Stop processing
      return;
    }
    
    // Show success toast
    showToast('User created successfully', 'success');
    // Close modal
    closeModal('addUserModal');
    // Reload users table
    loadUsers();
    // Reload dropdowns
    loadUsersForDropdowns();
  } catch (error) {
    // Log error to console
    console.error('Error creating user:', error);
    // Show error message
    document.getElementById('addUserError').textContent = 'Failed to create user';
  } finally {
    // Hide loading state
    showLoading(false);
  }
}

// Function to handle edit user form submission
async function handleEditUser(e) {
  // Prevent default form submission
  e.preventDefault();
  // Clear previous error messages
  document.getElementById('editUserError').textContent = '';
  
  // Get form field values
  const name = document.getElementById('editUserName').value.trim();
  const age = document.getElementById('editUserAge').value.trim();
  const gender = document.getElementById('editUserGender').value;
  const employmentId = document.getElementById('editUserEmploymentId').value.trim();
  const role = document.getElementById('editUserRole').value;
  const password = document.getElementById('editUserPassword').value.trim();
  
  // Validate required fields
  if (!name || !employmentId || !role) {
    // Show error message
    document.getElementById('editUserError').textContent = 'Name, Employment ID, and Role are required';
    // Stop form processing
    return;
  }
  
  // Validate age if provided
  if (age) {
    // Parse age as integer
    const ageNum = parseInt(age);
    // Check if age is valid (1-99)
    if (!Number.isInteger(ageNum) || ageNum < 1 || ageNum > 99) {
      // Show error message
      document.getElementById('editUserError').textContent = 'Age must be between 1 and 99';
      // Stop form processing
      return;
    }
  }
  
  // Indicate loading state
  showLoading(true);
  try {
    // Send update user request to API
    const response = await fetch(`/api/superadmin/users/${editingUserId}`, {
      method: 'PUT',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        name,
        age: age ? parseInt(age) : null,
        gender: gender || null,
        employment_id: employmentId,
        role,
        password: password || undefined
      })
    });
    
    // Check if request was successful
    if (!response.ok) {
      // Parse error response
      const error = await response.json();
      // Show error message
      document.getElementById('editUserError').textContent = error.error;
      // Stop processing
      return;
    }
    
    // Show success toast
    showToast('User updated successfully', 'success');
    // Close modal
    closeModal('editUserModal');
    // Reload users table
    loadUsers();
    // Reload dropdowns
    loadUsersForDropdowns();
  } catch (error) {
    // Log error to console
    console.error('Error updating user:', error);
    // Show error message
    document.getElementById('editUserError').textContent = 'Failed to update user';
  } finally {
    // Hide loading state
    showLoading(false);
  }
}

// Function to delete user
async function deleteUser(userId) {
  // Show confirmation dialog
  if (!confirm('Are you sure you want to delete this user?')) return;
  
  // Indicate loading state
  showLoading(true);
  try {
    // Send delete user request to API
    const response = await fetch(`/api/superadmin/users/${userId}`, {
      method: 'DELETE'
    });
    
    // Check if request was successful
    if (!response.ok) {
      // Parse error response
      const error = await response.json();
      // Show error toast
      showToast(error.error, 'error');
      // Stop processing
      return;
    }
    
    // Show success toast
    showToast('User deleted successfully', 'success');
    // Reload users table
    loadUsers();
    // Reload dropdowns
    loadUsersForDropdowns();
  } catch (error) {
    // Log error to console
    console.error('Error deleting user:', error);
    // Show error toast
    showToast('Failed to delete user', 'error');
  } finally {
    // Hide loading state
    showLoading(false);
  }
}

// Function to load issues
async function loadIssues() {
  // Indicate loading state
  showLoading(true);
  try {
    // Fetch all issues from API
    const response = await fetch('/api/troubleshoot');
    // Parse response JSON
    allIssues = await response.json();
    
    // Display issues in table
    displayIssuesTable();
  } catch (error) {
    // Log error to console
    console.error('Error loading issues:', error);
    // Show error toast to user
    showToast('Failed to load issues', 'error');
  } finally {
    // Hide loading state
    showLoading(false);
  }
}

// Function to display issues in HTML table
function displayIssuesTable() {
  // Get table body element
  const tbody = document.getElementById('issuesTableBody');
  // Build HTML for each issue row
  let html = '';
  // Loop through all issues
  allIssues.forEach(issue => {
    // Find project name for this issue
    const project = allProjects.find(p => p.id === issue.project_id);
    // Create table row HTML with issue data
    html += `
      <tr>
        <td>${project?.name || 'Unknown'}</td>
        <td>${issue.title}</td>
        <td><span class="badge badge-${issue.status === 'open' ? 'danger' : issue.status === 'escalated' ? 'warning' : 'success'}">${issue.status}</span></td>
        <td>${formatDate(issue.created_at)}</td>
        <td>
          ${issue.status !== 'resolved' ? `<button class="btn btn-sm btn-success" style="padding: 4px 8px; font-size: 12px;" onclick="resolveIssue(${issue.id})">Resolve</button>` : '-'}
        </td>
      </tr>
    `;
  });
  // Set table body HTML
  tbody.innerHTML = html || '<tr><td colspan="5">No issues found</td></tr>';
}

// Function to resolve an issue
async function resolveIssue(issueId) {
  // Indicate loading state
  showLoading(true);
  try {
    // Send resolve issue request to API
    const response = await fetch(`/api/troubleshoot/${issueId}/resolve`, {
      method: 'PUT',
      headers: { 'Content-Type': 'application/json' }
    });
    
    // Check if request was successful
    if (!response.ok) {
      // Parse error response
      const error = await response.json();
      // Show error toast
      showToast(error.error, 'error');
      // Stop processing
      return;
    }
    
    // Show success toast
    showToast('Issue resolved', 'success');
    // Reload issues table
    loadIssues();
  } catch (error) {
    // Log error to console
    console.error('Error resolving issue:', error);
    // Show error toast
    showToast('Failed to resolve issue', 'error');
  } finally {
    // Hide loading state
    showLoading(false);
  }
}

// Function to export users to CSV
function exportUsersCSV() {
  // Build CSV header row
  let csv = 'Name,Age,Gender,Employment ID,Role,User ID,Created Date\n';
  // Loop through all users
  allUsers.forEach(user => {
    // Add user data as CSV row
    csv += `"${user.name}","${user.age || ''}","${user.gender || ''}","${user.employment_id}","${user.role}","${user.user_id}","${formatDate(user.created_at)}"\n`;
  });
  
  // Create blob from CSV string
  const blob = new Blob([csv], { type: 'text/csv' });
  // Create download link
  const url = window.URL.createObjectURL(blob);
  // Create temporary anchor element
  const a = document.createElement('a');
  // Set download link
  a.href = url;
  // Set download filename
  a.download = `users-${new Date().toISOString().split('T')[0]}.csv`;
  // Trigger download
  a.click();
  // Clean up URL object
  window.URL.revokeObjectURL(url);
  // Show success message
  showToast('Users exported successfully', 'success');
}

// Function to handle create project form submission
async function handleCreateProject(e) {
  // Prevent default form submission
  e.preventDefault();
  
  // Get form field values
  const projectName = document.getElementById('projectName').value.trim();
  const location = document.getElementById('projectLocation').value.trim();
  const city = document.getElementById('projectCity').value.trim();
  const contractorName = document.getElementById('contractorName').value.trim();
  
  // Get selected project managers
  const pmSelect = document.getElementById('projectManagerSelect');
  const selectedPMs = Array.from(pmSelect.selectedOptions).map(opt => parseInt(opt.value));
  
  // Get selected site engineers
  const seSelect = document.getElementById('siteEngineerSelect');
  const selectedSEs = Array.from(seSelect.selectedOptions).map(opt => parseInt(opt.value));
  
  // Get selected supervisors
  const supSelect = document.getElementById('supervisorSelect');
  const selectedSups = Array.from(supSelect.selectedOptions).map(opt => parseInt(opt.value));
  
  // Validate required fields
  if (!projectName || !location || !city) {
    // Show error toast
    showToast('Project name, location, and city are required', 'error');
    // Stop form processing
    return;
  }
  
  // Validate at least one user is selected for each role
  if (selectedPMs.length === 0 || selectedSEs.length === 0 || selectedSups.length === 0) {
    // Show error toast
    showToast('Please select at least one person for each role', 'error');
    // Stop form processing
    return;
  }
  
  // Indicate loading state
  showLoading(true);
  try {
    // Send create project request to API
    const response = await fetch('/api/projects', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        name: projectName,
        location,
        city,
        contractor_name: contractorName,
        project_managers: selectedPMs,
        site_engineers: selectedSEs,
        supervisors: selectedSups
      })
    });
    
    // Check if request was successful
    if (!response.ok) {
      // Parse error response
      const error = await response.json();
      // Show error toast
      showToast(error.error, 'error');
      // Stop processing
      return;
    }
    
    // Show success toast
    showToast('Project created successfully', 'success');
    // Reset form fields
    document.getElementById('createProjectForm').reset();
    // Reload projects list
    loadProjects();
  } catch (error) {
    // Log error to console
    console.error('Error creating project:', error);
    // Show error toast
    showToast('Failed to create project', 'error');
  } finally {
    // Hide loading state
    showLoading(false);
  }
}

// Initialize application on page load
document.addEventListener('DOMContentLoaded', () => {
  // Get auth token from localStorage
  const token = localStorage.getItem('auth_token');
  // Redirect to login if no token
  if (!token) {
    // Redirect to login page
    window.location.href = '/';
    // Stop execution
    return;
  }
  
  try {
    // Decode JWT token
    currentUser = decodeJWT(token);
    // Display user name in page
    document.getElementById('userName').textContent = currentUser.name;
  } catch (error) {
    // Log error to console
    console.error('Token error:', error);
    // Clear token from storage
    localStorage.removeItem('auth_token');
    // Redirect to login page
    window.location.href = '/';
  }
  
  // Setup navigation link click handlers
  document.querySelectorAll('.nav-link').forEach(link => {
    // Add click event listener to each nav link
    link.addEventListener('click', (e) => {
      // Prevent default link behavior
      e.preventDefault();
      // Get target section ID from href attribute
      const targetId = link.getAttribute('href').substring(1);
      // Remove active class from all nav links
      document.querySelectorAll('.nav-link').forEach(l => l.classList.remove('active'));
      // Add active class to clicked link
      link.classList.add('active');
      // Navigate to target section
      navigateTo(targetId);
    });
  });
  
  // Setup form submit handlers
  document.getElementById('createProjectForm').addEventListener('submit', handleCreateProject);
  document.getElementById('addUserForm').addEventListener('submit', handleAddUser);
  document.getElementById('editUserForm').addEventListener('submit', handleEditUser);
  
  // Setup filter input handlers
  document.getElementById('userNameFilter').addEventListener('keyup', filterUsers);
  document.getElementById('userRoleFilter').addEventListener('change', filterUsers);
  
  // Setup age input validation for add user form
  const addUserAgeInput = document.getElementById('addUserAge');
  // Add input event listener for age field
  addUserAgeInput.addEventListener('input', () => {
    // Remove any non-numeric characters
    addUserAgeInput.value = addUserAgeInput.value.replace(/[^0-9]/g, '');
    // Cap age at 99
    if (parseInt(addUserAgeInput.value) > 99) addUserAgeInput.value = 99;
    // Floor age at 1 if input exists
    if (parseInt(addUserAgeInput.value) < 1 && addUserAgeInput.value !== '') addUserAgeInput.value = 1;
  });
  
  // Setup age input validation for edit user form
  const editUserAgeInput = document.getElementById('editUserAge');
  // Add input event listener for age field
  editUserAgeInput.addEventListener('input', () => {
    // Remove any non-numeric characters
    editUserAgeInput.value = editUserAgeInput.value.replace(/[^0-9]/g, '');
    // Cap age at 99
    if (parseInt(editUserAgeInput.value) > 99) editUserAgeInput.value = 99;
    // Floor age at 1 if input exists
    if (parseInt(editUserAgeInput.value) < 1 && editUserAgeInput.value !== '') editUserAgeInput.value = 1;
  });
  
  // Load initial data
  loadStats();
  loadActivity();
  loadBudgetChart();
  loadUsers();
  loadProjects();
  loadIssues();
  loadUsersForDropdowns();
  
  // Refresh data every 30 seconds
  setInterval(() => {
    // Check if overview section is visible
    if (document.getElementById('overview').classList.contains('hidden') === false) {
      // Reload stats
      loadStats();
      // Reload activity
      loadActivity();
      // Reload budget chart
      loadBudgetChart();
    }
  }, 30000);
  
  // Add CSS animations
  const style = document.createElement('style');
  // Define slide out animation
  style.textContent = `
    @keyframes slideOutRight {
      from {
        transform: translateX(0);
        opacity: 1;
      }
      to {
        transform: translateX(400px);
        opacity: 0;
      }
    }
  `;
  // Append styles to document head
  document.head.appendChild(style);
});
