// Superadmin Dashboard JS - Complete implementation with all features

let currentUser = null;
// Chart instance for budget visualization
let budgetChart = null;
// Array to store all users fetched from database
let allUsers = [];
// Array to store all projects fetched from database
let allProjects = [];
// Array to store all issues fetched from database
let allIssues = [];
// Object to store users grouped by role for dropdown filtering
let usersByRole = {};
// Variable to track current edit user ID
let editingUserId = null;

// Function to display toast notification to user
function showToast(message, type = 'info') {
  // Get or create toast container element
  const container = document.getElementById('toastContainer') || createToastContainer();
  // Create new toast div element
  const toast = document.createElement('div');
  // Add toast and type class for styling
  toast.className = `toast ${type}`;
  // Set toast message text
  toast.textContent = message;
  // Append toast to container
  container.appendChild(toast);
  
  // Automatically hide toast after 3 seconds
  setTimeout(() => {
    // Start slide out animation
    toast.style.animation = 'slideOutRight 0.3s ease-out forwards';
    // Remove toast element after animation completes
    setTimeout(() => toast.remove(), 300);
  }, 3000);
}

// Function to create toast container element
function createToastContainer() {
  // Create new div for toast container
  const container = document.createElement('div');
  // Set container ID
  container.id = 'toastContainer';
  // Add CSS class for positioning
  container.className = 'toast-container';
  // Append container to page body
  document.body.appendChild(container);
  // Return container reference
  return container;
}

// Function to show/hide loading overlay
function showLoading(show = true) {
  // Get loading overlay element from DOM
  const overlay = document.getElementById('loadingOverlay');
  // Show or hide overlay based on parameter
  if (overlay) {
    // Toggle 'show' class to display/hide overlay
    overlay.classList.toggle('show', show);
  }
}

// Function to get cookie value by name
function getCookie(name) {
  // Create search string for cookie
  const nameEQ = name + '=';
  // Split all cookies by semicolon
  const cookies = document.cookie.split(';');
  // Loop through each cookie
  for (let i = 0; i < cookies.length; i++) {
    // Trim whitespace from cookie
    let cookie = cookies[i].trim();
    // Check if cookie starts with our search string
    if (cookie.indexOf(nameEQ) === 0) {
      // Return cookie value without the name part
      return cookie.substring(nameEQ.length, cookie.length);
    }
  }
  // Return null if cookie not found
  return null;
}

// Function to decode JWT token from localStorage
function decodeJWT(token) {
  // Split token into three parts (header.payload.signature)
  const base64Url = token.split('.')[1];
  // Replace URL-safe characters with standard base64 characters
  const base64 = base64Url.replace(/-/g, '+').replace(/_/g, '/');
  // Decode base64 and convert to UTF-8 string
  const jsonPayload = decodeURIComponent(atob(base64).split('').map(c => {
    // Convert each character to percent-encoded format
    return '%' + ('00' + c.charCodeAt(0).toString(16)).slice(-2);
  }).join(''));
  // Parse JSON string to object and return
  return JSON.parse(jsonPayload);
}

// Function to logout current user
async function logoutUser() {
  // Show confirmation dialog
  if (!confirm('Are you sure you want to logout?')) return;
  try {
    // Send logout request to backend
    await fetch('/api/auth/logout', { method: 'POST' });
  } finally {
    // Clear token from localStorage
    localStorage.removeItem('auth_token');
    // Redirect to login page
    window.location.href = '/';
  }
}

// Function to format date to readable string
function formatDate(dateStr) {
  // Return empty string if no date provided
  if (!dateStr) return '';
  // Create date object from string
  const date = new Date(dateStr);
  // Format date using Indian locale (DD MMM YYYY HH:MM format)
  return new Intl.DateTimeFormat('en-IN', {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
    hour: '2-digit',
    minute: '2-digit',
    timeZone: 'Asia/Kolkata'
  }).format(date);
}

// Function to open modal dialog by ID
function openModal(modalId) {
  // Get modal element from DOM
  const modal = document.getElementById(modalId);
  // Show modal by adding 'show' class
  if (modal) {
    // Add show class to display modal
    modal.classList.add('show');
  }
}

// Function to close modal dialog by ID
function closeModal(modalId) {
  // Get modal element from DOM
  const modal = document.getElementById(modalId);
  // Hide modal by removing 'show' class
  if (modal) {
    // Remove show class to hide modal
    modal.classList.remove('show');
  }
}

// Function to navigate to different page sections
function navigateTo(sectionId) {
  // Hide all page sections
  document.querySelectorAll('.page-section').forEach(section => {
    // Add hidden class to all sections
    section.classList.add('hidden');
  });
  
  // Show selected section
  const section = document.getElementById(sectionId);
  // Show only the selected section
  if (section) {
    // Remove hidden class from target section
    section.classList.remove('hidden');
  }
  
  // Update navigation link styles
  document.querySelectorAll('.nav-link').forEach(link => {
    // Remove active class from all nav links
    link.classList.remove('active');
  });
  // Add active class to clicked link
  event.target.classList.add('active');
}

// Function to load KPI statistics from backend
async function loadStats() {
  // Indicate loading state
  showLoading(true);
  try {
    // Fetch statistics from API
    const response = await fetch('/api/superadmin/stats');
    // Parse response JSON
    const stats = await response.json();
    
    // Update KPI card for total projects
    document.getElementById('totalProjects').textContent = stats.totalProjects;
    // Update KPI card for active projects
    document.getElementById('activeProjects').textContent = stats.activeProjects;
    // Update KPI card for total users
    document.getElementById('totalUsers').textContent = stats.totalUsers;
    // Update KPI card for open issues
    document.getElementById('openIssues').textContent = stats.openIssues;
    // Update KPI card for workers on site
    document.getElementById('workersOnSite').textContent = stats.workersOnSite;
    // Update KPI card for uploaded documents
    document.getElementById('documentsUploaded').textContent = stats.documentsUploaded;
    
    // Update gender breakdown bar chart if stats include breakdown
    if (stats.workerGenderBreakdown) {
      // Get container for gender stats
      const container = document.getElementById('genderBreakdownStats');
      // Build HTML for gender breakdown display
      let html = '<div style="display: flex; gap: 20px; margin-top: 15px;">';
      // Add male workers count
      html += `<div><strong>Male:</strong> ${stats.workerGenderBreakdown.male || 0}</div>`;
      // Add female workers count
      html += `<div><strong>Female:</strong> ${stats.workerGenderBreakdown.female || 0}</div>`;
      // Add other gender workers count
      html += `<div><strong>Other:</strong> ${stats.workerGenderBreakdown.other || 0}</div>`;
      // Close HTML container
      html += '</div>';
      // Set gender breakdown HTML in container
      if (container) container.innerHTML = html;
    }
  } catch (error) {
    // Log error to console
    console.error('Error loading stats:', error);
    // Show error toast to user
    showToast('Failed to load statistics', 'error');
  } finally {
    // Hide loading state
    showLoading(false);
  }
}

// Function to load recent activity feed
async function loadActivity() {
  // Indicate loading state
  showLoading(true);
  try {
    // Fetch activity from API
    const response = await fetch('/api/superadmin/activity');
    // Parse response JSON
    const activity = await response.json();
    
    // Get activity container element
    const container = document.getElementById('activityFeed');
    // Build HTML for activity list
    let html = '';
    // Loop through each activity item
    activity.forEach(item => {
      // Create HTML for single activity row
      html += `
        <div style="padding: 12px; border-bottom: 1px solid #eee;">
          <div style="font-size: 13px; color: #0F6E56; font-weight: 600;">${item.type.replace(/_/g, ' ').toUpperCase()}</div>
          <div style="font-size: 14px; margin: 5px 0;">${item.description}</div>
          <div style="font-size: 12px; color: #999;">${formatDate(item.created_at)}</div>
        </div>
      `;
    });
    // Set activity HTML in container
    container.innerHTML = html || '<div style="padding: 20px; text-align: center; color: #999;">No recent activity</div>';
  } catch (error) {
    // Log error to console
    console.error('Error loading activity:', error);
    // Show error toast to user
    showToast('Failed to load activity', 'error');
  } finally {
    // Hide loading state
    showLoading(false);
  }
}

// Function to load and display budget chart
async function loadBudgetChart() {
  // Indicate loading state
  showLoading(true);
  try {
    // Fetch budget data from API
    const response = await fetch('/api/budget');
    // Parse response JSON
    const budgetData = await response.json();
    
    // Group budget by date for last 30 days
    const dateMap = {};
    // Get current date
    const today = new Date();
    // Initialize 30 days of data
    for (let i = 29; i >= 0; i--) {
      // Create date 30 days ago
      const date = new Date(today);
      // Subtract i days
      date.setDate(date.getDate() - i);
      // Format date as YYYY-MM-DD
      const dateStr = date.toISOString().split('T')[0];
      // Initialize with 0 budget
      dateMap[dateStr] = 0;
    }
    
    // Sum budget amounts by date
    budgetData.forEach(record => {
      // Extract date from record
      const dateStr = record.date.split('T')[0];
      // Add amount to date total
      if (dateMap[dateStr] !== undefined) {
        dateMap[dateStr] += parseFloat(record.amount);
      }
    });
    
    // Extract sorted dates
    const dates = Object.keys(dateMap).sort();
    // Extract amounts in same order
    const amounts = dates.map(date => dateMap[date]);
    
    // Get chart canvas element
    const ctx = document.getElementById('budgetChart');
    // Destroy existing chart if present
    if (budgetChart) {
      budgetChart.destroy();
    }
    
    // Create new Chart.js instance
    budgetChart = new Chart(ctx, {
      // Chart type: line graph
      type: 'line',
      // Chart data configuration
      data: {
        // X-axis labels: dates
        labels: dates.map(d => new Date(d).toLocaleDateString('en-IN')),
        // Dataset configuration
        datasets: [{
          // Label for legend
          label: 'Daily Budget Spend',
          // Y-axis data: amounts
          data: amounts,
          // Line color
          borderColor: '#0F6E56',
          // Background color under line
          backgroundColor: 'rgba(15, 110, 86, 0.1)',
          // Line width in pixels
          borderWidth: 2,
          // Tension for curved lines
          tension: 0.4
        }]
      },
      // Chart options configuration
      options: {
        // Responsive chart scaling
        responsive: true,
        // Keep aspect ratio
        maintainAspectRatio: true,
        // Y-axis configuration
        scales: {
          y: {
            // Start Y-axis at 0
            beginAtZero: true,
            // Y-axis title
            title: {
              display: true,
              text: 'Amount (₹)'
            }
          }
        },
        // Plugin options
        plugins: {
          // Legend configuration
          legend: {
            display: true,
            position: 'top'
          }
        }
      }
    });
  } catch (error) {
    // Log error to console
    console.error('Error loading budget chart:', error);
  } finally {
    // Hide loading state
    showLoading(false);
  }
}

// Function to load users and display in table
async function loadUsers() {
  // Indicate loading state
  showLoading(true);
  try {
    // Fetch all users from API
    const response = await fetch('/api/superadmin/users');
    // Parse response JSON
    allUsers = await response.json();
    
    // Display users in table
    displayUsersTable();
  } catch (error) {
    // Log error to console
    console.error('Error loading users:', error);
    // Show error toast to user
    showToast('Failed to load users', 'error');
  } finally {
    // Hide loading state
    showLoading(false);
  }
}

// Function to display users in HTML table
function displayUsersTable() {
  // Get table body element
  const tbody = document.getElementById('usersTableBody');
  // Build HTML for each user row
  let html = '';
  // Loop through all users
  allUsers.forEach(user => {
    // Create table row HTML with all user data
    html += `
      <tr>
        <td>${user.name}</td>
        <td>${user.age || '-'}</td>
        <td>${user.gender || '-'}</td>
        <td>${user.employment_id}</td>
        <td><span class="badge badge-primary">${user.role.replace(/_/g, ' ')}</span></td>
        <td>${user.user_id}</td>
        <td>${formatDate(user.created_at)}</td>
        <td>
          <button class="btn btn-sm" style="padding: 4px 8px; font-size: 12px;" onclick="openEditUserModal(${user.id}, '${user.name}', ${user.age || 'null'}, '${user.gender || ''}', '${user.employment_id}', '${user.role}', '${user.user_id}')">Edit</button>
          <button class="btn btn-sm btn-danger" style="padding: 4px 8px; font-size: 12px;" onclick="deleteUser(${user.id})">Delete</button>
        </td>
      </tr>
    `;
  });
  // Set table body HTML
  tbody.innerHTML = html || '<tr><td colspan="8">No users found</td></tr>';
}

// Function to load and populate user selects for project creation
async function loadUsersForDropdowns() {
  // Indicate loading state
  showLoading(true);
  try {
    // Fetch project managers
    const pmResponse = await fetch('/api/superadmin/users?role=project_manager');
    usersByRole.pm = await pmResponse.json();
    
    // Fetch site engineers
    const seResponse = await fetch('/api/superadmin/users?role=site_engineer');
    usersByRole.se = await seResponse.json();
    
    // Fetch supervisors
    const supResponse = await fetch('/api/superadmin/users?role=supervisor');
    usersByRole.supervisor = await supResponse.json();
    
    // Populate dropdowns in create project form
    populateProjectUserSelects();
  } catch (error) {
    // Log error to console
    console.error('Error loading users for dropdowns:', error);
    // Show error toast to user
    showToast('Failed to load users', 'error');
  } finally {
    // Hide loading state
    showLoading(false);
  }
}

// Function to populate user selection dropdowns in project form
function populateProjectUserSelects() {
  // Clear and populate project manager select
  const pmSelect = document.getElementById('projectManagerSelect');
  // Reset select HTML
  pmSelect.innerHTML = '<option value="">Select Project Manager(s)</option>';
  // Loop through project managers
  usersByRole.pm.forEach(user => {
    // Create option element for each PM
    const option = document.createElement('option');
    // Set option value to user ID
    option.value = user.id;
    // Set option text to user name and ID
    option.textContent = `${user.name} (${user.user_id})`;
    // Append option to select
    pmSelect.appendChild(option);
  });
  
  // Clear and populate site engineer select
  const seSelect = document.getElementById('siteEngineerSelect');
  // Reset select HTML
  seSelect.innerHTML = '<option value="">Select Site Engineer(s)</option>';
  // Loop through site engineers
  usersByRole.se.forEach(user => {
    // Create option element for each SE
    const option = document.createElement('option');
    // Set option value to user ID
    option.value = user.id;
    // Set option text to user name and ID
    option.textContent = `${user.name} (${user.user_id})`;
    // Append option to select
    seSelect.appendChild(option);
  });
  
  // Clear and populate supervisor select
  const supSelect = document.getElementById('supervisorSelect');
  // Reset select HTML
  supSelect.innerHTML = '<option value="">Select Supervisor(s)</option>';
  // Loop through supervisors
  usersByRole.supervisor.forEach(user => {
    // Create option element for each supervisor
    const option = document.createElement('option');
    // Set option value to user ID
    option.value = user.id;
    // Set option text to user name and ID
    option.textContent = `${user.name} (${user.user_id})`;
    // Append option to select
    supSelect.appendChild(option);
  });
}

